}

# ─────────────────────────────────────────────────────────────────────────────
# 4. FUNCIÓN DE RESOLUCIÓN (SIN INFERENCIAS)
# ─────────────────────────────────────────────────────────────────────────────
def resolver_ics(ics_codigo):
    ics_limpio = str(ics_codigo).strip()

    if ics_limpio in ics_to_hs:
        return ics_to_hs[ics_limpio]

    return f'ICS_{ics_limpio}'

# ─────────────────────────────────────────────────────────────────────────────
# 5. FUNCIÓN PARA LLAVE DESDE HS
# ─────────────────────────────────────────────────────────────────────────────
def llave_desde_hs(hs_codigo):
    clean = str(hs_codigo).replace('.', '').strip()
    if len(clean) <= 2:
        return clean
    else:
        return clean[:4] if len(clean) >= 4 else clean[:2]

# ─────────────────────────────────────────────────────────────────────────────
# 6. EXPLOSIÓN DE FILAS
# ─────────────────────────────────────────────────────────────────────────────
rows = []

for _, row in df.iterrows():
    hs_list  = row['HS_Clean_List']
    ics_list = row['ICS_Clean_List']

    if not hs_list and not ics_list:
        continue

    # Prioridad 1: HS
    if hs_list:
        for hs in hs_list:
            new_row = row.copy()
            new_row['HS_Separado']  = hs
            new_row['ICS_Separado'] = ''
            new_row['Llave_Cruce']  = llave_desde_hs(hs)
            rows.append(new_row)

    # Prioridad 2: ICS
    else:
        for ics in ics_list:
            new_row = row.copy()
            new_row['HS_Separado']  = ''
            new_row['ICS_Separado'] = ics.strip()
            new_row['Llave_Cruce']  = resolver_ics(ics)
            rows.append(new_row)

# ─────────────────────────────────────────────────────────────────────────────
# 7. DATAFRAME FINAL
# ─────────────────────────────────────────────────────────────────────────────
df_final = pd.DataFrame(rows)

columnas_mantener = [
    'Distribution date', 'Document symbol', 'Title', 'Description',
    'Products covered', 'HS code(s)', 'HS_Separado',
    'ICS code(s)', 'ICS_Separado',
    'Objectives', 'Proposed date of adoption',
    'Proposed date of entry into force',
    'Link to notification(EN)', 'Llave_Cruce'
]

df_final = df_final[[c for c in columnas_mantener if c in df_final.columns]]

df_final['HS_Separado']  = df_final['HS_Separado'].fillna('')
df_final['ICS_Separado'] = df_final['ICS_Separado'].fillna('')

# ─────────────────────────────────────────────────────────────────────────────
# 8. EXPORTACIÓN
# ─────────────────────────────────────────────────────────────────────────────
