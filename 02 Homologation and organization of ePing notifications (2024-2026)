    '31.020': '85',
    '33.060': '85',

    '35.260': '84',

    '43.080': '87',

    '47.020.70': '90',

    '65.020.20': '01-24',
    '65.020.30': '01-24',
    '65.080': '01-24',
    '65.100': '01-24',
    '65.120': '01-24',

    '67': '16-24',

    '71.100': '28-38',
    '71.100.70': '28-38',
    '71.120': '28-38',

