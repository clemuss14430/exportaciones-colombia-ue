import pandas as pd 
import numpy as np
import re

# ─────────────────────────────────────────────────────────────────────────────
# 1. CARGA Y FILTRO INICIAL
# ─────────────────────────────────────────────────────────────────────────────
df_raw = pd.read_excel('Notifications (Jan 2024 - Today).xlsx')

df = df_raw[
    (df_raw['Notifying Member'] == 'European Union') &
    (df_raw['Objectives'].str.contains('environment', case=False, na=False))
].copy()

print(f"Notificaciones UE ambientales en bruto: {len(df)}")

# ─────────────────────────────────────────────────────────────────────────────
# 2. FUNCIÓN DE EXTRACCIÓN DE CÓDIGOS
# ─────────────────────────────────────────────────────────────────────────────
def extraer_lista_codigos(texto):
    if pd.isna(texto) or str(texto).strip().lower() in ('nan', 'none', '', '.'):
        return []
    elementos = str(texto).split(';')
    codigos = []
    for item in elementos:
        item = item.strip()
        match = re.search(r'(\d[\d\.]+)', item)
        if match:
            codigo = match.group(1).strip('.')
            if codigo:
                codigos.append(codigo)
    return list(set(codigos))

df['HS_Clean_List']  = df['HS code(s)'].apply(extraer_lista_codigos)
df['ICS_Clean_List'] = df['ICS code(s)'].apply(extraer_lista_codigos)

# ─────────────────────────────────────────────────────────────────────────────
# 3. DICCIONARIO EXACTO (SOLO EL DEL EXCEL V4)
# ─────────────────────────────────────────────────────────────────────────────
ics_to_hs = {

    '07.080': '90',

    '11.120': '30',
    '11.220': '30',

    '13.020': 'ENV-General',
    '13.030.30': 'ENV-General',
    '13.040.50': 'ENV-General',
    '13.220.10': 'ENV-General',
    '13.220.20': 'ENV-General',

    '29.060.01': '85',
